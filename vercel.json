{
    "version": 2,
    "builds": [
        {
            "src": "backend/core/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "backend/core/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_DEBUG": "False",
        "PYTHON_VERSION": "3.12"
    }
}