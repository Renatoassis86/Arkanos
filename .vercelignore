# Vercel Ignore - Optimized for Arkanos RPG
# Main Goal: Keep bundle < 250MB while including all high-quality PNGs

# Python/System
venv/
.venv/
__pycache__/
*.pyc
node_modules/
*.log
.DS_Store
.vercel/
.vercel_cache/

# Heavy Archives
**/*.rar
**/*.zip
**/*.7z
**/*.exe

# Database
db.sqlite3

# Consolidado: Ignoramos as pastas estáticas redundantes
/static/
/staticfiles/

# Staticfiles processado - Mantemos apenas o do backend
!backend/static/
!backend/staticfiles/

# CRITICAL OVERRIDE: Ignore these heavy files regardless of folder inclusion
**/*.mp4
**/*.mp3
**/*.wav
**/*.mov
**/*.MOV
**/*.avi
**/*.wmv
**/*.zip
**/*.rar
**/videos/
**/video/
**/staticfiles/videos/
**/staticfiles/video/