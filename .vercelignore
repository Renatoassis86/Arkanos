# Vercel Ignore - Optimized for Arkanos RPG
# Main Goal: Keep bundle < 250MB while including all high-quality PNGs

# Python/System
venv/
.venv/
__pycache__/
*.pyc
node_modules/
*.log
.DS_Store
.vercel/
.vercel_cache/

# Heavy Archives
**/*.rar
**/*.zip
**/*.7z
**/*.exe

# Database
db.sqlite3

# Consolidado: Ignoramos a pasta 'static' raiz (180MB) pois migramos o necessário para 'backend/static'
static/

# Vídeos (Sempre no Supabase - 0MB no bundle)
**/*.mp4
**/*.mov

# Staticfiles processado - DEVE ser enviado
!staticfiles/
!backend/staticfiles/